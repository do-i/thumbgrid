{
    "_meta": {
        "id": "leftie",
        "name": "Leftie",
        "description": "Southpaw-friendly key selection - turns out keys pick their own friends, and this bunch all huddled on the right hand",
        "os": [
            "linux",
            "windows",
            "macos"
        ],
        "order": 50,
        "source": "House blend - not modeled on any app, just how the maintainer's hands happen to land"
    },
    "global": {
        "closeFullScreenOrExit": [
            "Esc"
        ],
        "contextMenu": [
            "Menu",
            "RMB"
        ],
        "copyFile": [
            "$Alt+C"
        ],
        "copyFileClipboard": [
            "$Ctrl+C"
        ],
        "copyPathClipboard": [
            "$Ctrl+$Shift+C"
        ],
        "cutFile": [
            "$Ctrl+X"
        ],
        "exit": [
            "$Alt+X",
            "$Ctrl+Q"
        ],
        "moveFile": [
            "M"
        ],
        "moveToTrash": [
            "Del"
        ],
        "open": [
            "$Ctrl+O"
        ],
        "openSettings": [
            "F12",
            "P"
        ],
        "pasteFile": [
            "$Ctrl+V"
        ],
        "removeFile": [
            "$Shift+Del"
        ],
        "renameFile": [
            "F2"
        ],
        "showInDirectory": [
            "$Ctrl+D"
        ],
        "toggleFullscreen": [
            "F",
            "F11",
            "LMB_DoubleClick"
        ],
        "togglePlacesPanel": [
            "$Ctrl+E"
        ],
        "toggleShuffle": [
            "$Ctrl+`"
        ],
        "toggleStatusFooter": [
            "$Ctrl+B"
        ]
    },
    "document": {
        "crop": [
            "N"
        ],
        "discardEdits": [
            "$Ctrl+Z"
        ],
        "fitNormal": [
            "1"
        ],
        "fitWindow": [
            "0",
            "W"
        ],
        "flipH": [
            "J"
        ],
        "flipV": [
            "K"
        ],
        "folderView": [
            "U"
        ],
        "frameStep": [
            "."
        ],
        "frameStepBack": [
            ","
        ],
        "jumpToFirst": [
            "Home"
        ],
        "jumpToLast": [
            "End"
        ],
        "nextDirectory": [
            "$Shift+Right"
        ],
        "nextImage": [
            "PgDown",
            "Right",
            "WheelDown",
            "XButton2"
        ],
        "prevDirectory": [
            "$Shift+Left"
        ],
        "prevImage": [
            "Left",
            "PgUp",
            "WheelUp",
            "XButton1"
        ],
        "reloadImage": [
            "F5"
        ],
        "resize": [
            "$Shift+S"
        ],
        "rotateLeft": [
            "H"
        ],
        "rotateRight": [
            "L"
        ],
        "saveAs": [
            "$Ctrl+S"
        ],
        "seekVideoBackward": [
            "$Ctrl+Left"
        ],
        "seekVideoForward": [
            "$Ctrl+Right"
        ],
        "toggleFullscreenInfoBar": [
            "$Shift+F"
        ],
        "toggleSlideshow": [
            "`"
        ],
        "zoomIn": [
            "$Ctrl++",
            "$Ctrl+=",
            "I"
        ],
        "zoomInCursor": [
            "$Ctrl+WheelUp"
        ],
        "zoomOut": [
            "$Ctrl+-",
            "O"
        ],
        "zoomOutCursor": [
            "$Ctrl+WheelDown"
        ]
    },
    "grid": {
        "createDirectory": [
            "F7"
        ],
        "folderView": [
            "U"
        ],
        "nextDirectory": [
            "$Shift+Right"
        ],
        "prevDirectory": [
            "$Shift+Left"
        ],
        "toggleFolderViewTopBar": [
            "$Ctrl+T"
        ]
    }
}
