{
    "_meta": {
        "id": "irfanview",
        "name": "IrfanView-style",
        "description": "Shortcuts modeled on IrfanView defaults",
        "os": ["windows"],
        "order": 40,
        "source": "Illustrative partial reconstruction of IrfanView defaults",
        "notice": "Independent reconstruction; 'IrfanView' is a trademark of its owner; not affiliated."
    },
    "global": {
        "toggleFullscreen": ["Enter"],
        "openSettings": ["P"],
        "moveToTrash": ["Del"]
    },
    "document": {
        "nextImage": ["Space", "Right"],
        "prevImage": ["Backspace", "Left"]
    },
    "grid": {
        "moveFile": ["M"],
        "removeFile": ["$Shift+Del"],
        "renameFile": ["F2"]
    }
}
