{
    "_comment": "Default keyboard/mouse shortcuts, seeded into every context on first run or reset. $Ctrl/$Alt/$Shift are placeholders replaced at load with the platform modifier names (Ctrl/Alt/Shift, or the Command/Option/Shift symbols on macOS). 'platform.apple' entries are used on macOS, 'platform.default' everywhere else. Installed to /etc/thumbgrid/default-shortcuts.json (admin-editable) with a copy embedded in the binary as a fallback.",
    "shortcuts": {
        "Right": "nextImage",
        "Left": "prevImage",
        "XButton2": "nextImage",
        "XButton1": "prevImage",
        "WheelDown": "nextImage",
        "WheelUp": "prevImage",
        "F": "toggleFullscreen",
        "F11": "toggleFullscreen",
        "LMB_DoubleClick": "toggleFullscreen",
        "Space": "toggleFitMode",
        "1": "fitWindow",
        "2": "fitWidth",
        "3": "fitNormal",
        "4": "fitWindowStretch",
        "R": "resize",
        "H": "flipH",
        "V": "flipV",
        "$Ctrl+R": "rotateRight",
        "$Ctrl+L": "rotateLeft",
        "$Ctrl+WheelUp": "zoomInCursor",
        "$Ctrl+WheelDown": "zoomOutCursor",
        "=": "zoomIn",
        "$Ctrl+=": "zoomIn",
        "+": "zoomIn",
        "$Ctrl++": "zoomIn",
        "-": "zoomOut",
        "$Ctrl+-": "zoomOut",
        "$Ctrl+Down": "zoomOut",
        "$Ctrl+Up": "zoomIn",
        "Up": "scrollUp",
        "Down": "scrollDown",
        "$Ctrl+O": "open",
        "$Ctrl+S": "save",
        "$Ctrl+$Shift+S": "saveAs",
        "$Ctrl+W": "setWallpaper",
        "X": "crop",
        "$Ctrl+P": "print",
        "$Alt+X": "exit",
        "$Ctrl+Q": "exit",
        "Esc": "closeFullScreenOrExit",
        "Del": "moveToTrash",
        "$Shift+Del": "removeFile",
        "C": "copyFile",
        "M": "moveFile",
        "Home": "jumpToFirst",
        "End": "jumpToLast",
        "$Ctrl+Right": "seekVideoForward",
        "$Ctrl+Left": "seekVideoBackward",
        ",": "frameStepBack",
        ".": "frameStep",
        "Enter": "folderView",
        "Backspace": "folderView",
        "F5": "reloadImage",
        "$Ctrl+C": "copyFileClipboard",
        "$Ctrl+$Shift+C": "copyPathClipboard",
        "F2": "renameFile",
        "F7": "createDirectory",
        "RMB": "contextMenu",
        "Menu": "contextMenu",
        "I": "toggleImageInfo",
        "$Ctrl+`": "toggleShuffle",
        "$Ctrl+D": "showInDirectory",
        "`": "toggleSlideshow",
        "$Ctrl+Z": "discardEdits",
        "U": "folderView",
        "$Ctrl+T": "toggleFolderViewTopBar",
        "$Ctrl+B": "toggleStatusFooter",
        "$Ctrl+E": "togglePlacesPanel",
        "$Shift+Right": "nextDirectory",
        "$Shift+Left": "prevDirectory",
        "$Shift+F": "toggleFullscreenInfoBar",
        "$Ctrl+V": "pasteFile",
        "$Ctrl+X": "cutFile",
        "F12": "openSettings"
    },
    "platform": {
        "apple": {
            "$Alt+Up": "zoomIn",
            "$Alt+Down": "zoomOut",
            "$Ctrl+Comma": "openSettings"
        },
        "default": {
            "P": "openSettings"
        }
    }
}
